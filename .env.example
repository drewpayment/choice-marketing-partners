# Database Configuration
DATABASE_URL="mysql://user:password@localhost:3306/choice_marketing"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"
NEXT_PUBLIC_ENV=development

# Optional: canonical site URL. When set, takes precedence over Vercel's
# system env vars (NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL,
# NEXT_PUBLIC_VERCEL_URL). Used by getSiteUrl() to build absolute URLs for
# shareable QR codes and similar. Set this only when you want to pin to a
# custom domain (e.g. choicemarketingpartners.com); on Vercel without it,
# the helper falls back to the deployment's vercel.app URL.
# NEXT_PUBLIC_SITE_URL="https://choicemarketingpartners.com"

# Resend Email (required for password reset emails)
RESEND_API_KEY="your-resend-api-key"

# Careers HR notification recipient (falls back to RESEND_FROM_EMAIL, then a hardcoded default)
CAREERS_NOTIFY_EMAIL="careers@choicemarketingpartners.com"

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
